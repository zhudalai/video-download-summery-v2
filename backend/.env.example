# 后端配置
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# 生产: postgresql+asyncpg://user:pass@host/dbname

# Supabase Auth
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-here

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# YouTube Cookie(解决 429 限流,可选)
# 方式1: Cookie 文件路径(Render 推荐)
# YOUTUBE_COOKIE_PATH=/etc/secrets/youtube_cookie.txt
# 方式2: Cookie 文本内容(直接粘贴)
# YOUTUBE_COOKIE=Netscape HTTP Cookie File...

# App
APP_ENV=development
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# 字幕配置
# 是否下载自动生成字幕(YouTube 自动字幕可能触发 429 限流)
# False: 只下载人工字幕(默认,稳定)
# True: 同时下载自动字幕(可能触发 429,但能获取更多字幕)
DOWNLOAD_AUTO_SUBTITLES=False
